// tsconfig.app.json
{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",                          // ✅ requerido para paths
    "allowSyntheticDefaultImports": true,    // ✅
    "paths": {                               // ✅ alias para TypeScript
      "@/*":         ["./src/*"],
      "@core/*":     ["./src/core/*"],
      "@services/*": ["./src/services/*"],
      "@ui/*":       ["./src/ui/*"],
      "@utils/*":    ["./src/utils/*"]
    }
  },
  "include": ["src"]
}